<%- include('header'); -%>

 <div class="purchaseForm " >

    <form action="/newEntry" method="post">
     
     <div class=" form-row " >
      <div class="form-group col-md-6">
      <label for="date">The date of purchase:</label>
      <input  class="form-control" type="date" name="date" placeholder="dd.mm.yyyy" required>
      </div>
      
      <div class="form-group col-md-6">
      <label for="cryptoList">Purchased Cryptocurrency:</label>
        <input list="cryptoList" class="form-control datalistOptions" name="cryptoList" placeholder="e.g. Bitcoin" autocomplete="off" required/>
        <datalist id="cryptoList">
            <%  apiDatas.forEach(function (apiData) {%>
                <%  const cryptoName =apiData.cryptoName %>   
                <option value=<%= cryptoName %>>
                   
      <%  }) %> 
     
        </datalist>
        </div>
  
        <div class="form-group col-md-6">
        <label for="quantity">Purchased Quantity:</label>
        <input type="number" step="any" class="form-control " name="quantity" autocomplete="off" required>
        </div>
  
        <div class="form-group col-md-6">
        <label for="cost">Purchased Price $:</label>
        <input type="number" step="any" class="form-control is-invalid"  name="cost" autocomplete="off" required>
      </div>

      <div class="form-group col-md-3">
        <label for="side">Art Of Purchase:</label>
        <select name="side" class="form-control " id="" required>
            <option value="buy">BUY</option>
            <option value="sell">SELL</option>
        </select>
       
      </div>
     
      <button type="submit"  class="btn btn-outline-primary btn-lg " name="newEntry">New Entry</button>
    </div>
    </form>
  </div>
  <%- include('footer'); -%>